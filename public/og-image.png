<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#60a5fa;stop-opacity:1" />
    </linearGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
      <feMerge> 
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/> 
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bgGradient)"/>
  
  <!-- Geometric pattern -->
  <g opacity="0.1">
    <circle cx="100" cy="100" r="50" fill="white"/>
    <circle cx="1100" cy="530" r="80" fill="white"/>
    <rect x="900" y="50" width="60" height="60" fill="white" transform="rotate(45 930 80)"/>
    <polygon points="200,500 250,450 300,500 250,550" fill="white"/>
  </g>
  
  <!-- Shield icon -->
  <g transform="translate(100, 200)">
    <path d="M60 20 L60 20 C60 20 100 40 100 100 C100 160 60 200 60 200 C60 200 20 160 20 100 C20 40 60 20 60 20 Z" fill="white" filter="url(#glow)"/>
    <path d="M60 40 L80 60 L55 85 L40 70 Z" fill="#1e3a8a" stroke="white" stroke-width="2"/>
  </g>
  
  <!-- Main content -->
  <g transform="translate(250, 150)">
    <!-- Title -->
    <text x="0" y="80" font-family="Arial, sans-serif" font-size="72" font-weight="bold" fill="white">
      SESECPRO
    </text>
    
    <!-- Subtitle -->
    <text x="0" y="140" font-family="Arial, sans-serif" font-size="36" fill="#e0f2fe">
      Soluciones Avanzadas de Ciberseguridad
    </text>
    
    <!-- Description -->
    <text x="0" y="200" font-family="Arial, sans-serif" font-size="24" fill="#b3e5fc">
      Protegemos tus activos digitales con tecnología de vanguardia
    </text>
    
    <!-- Features -->
    <g transform="translate(0, 250)">
      <circle cx="15" cy="15" r="8" fill="#4ade80"/>
      <text x="35" y="22" font-family="Arial, sans-serif" font-size="20" fill="white">Evaluación de Riesgos</text>
      
      <circle cx="15" cy="55" r="8" fill="#4ade80"/>
      <text x="35" y="62" font-family="Arial, sans-serif" font-size="20" fill="white">Recursos Educativos</text>
      
      <circle cx="15" cy="95" r="8" fill="#4ade80"/>
      <text x="35" y="102" font-family="Arial, sans-serif" font-size="20" fill="white">Herramientas Especializadas</text>
    </g>
  </g>
  
  <!-- Website URL -->
  <text x="1050" y="600" font-family="Arial, sans-serif" font-size="18" fill="#e0f2fe" text-anchor="end">
    sesecpro.es
  </text>
</svg>