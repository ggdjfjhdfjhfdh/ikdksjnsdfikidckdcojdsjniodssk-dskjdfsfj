<svg width="1200" height="630" viewBox="0 0 1200 630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGradient2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0f172a;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#1e293b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#334155;stop-opacity:1" />
    </linearGradient>
    <radialGradient id="spotlight" cx="50%" cy="30%" r="60%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:0.3" />
      <stop offset="100%" style="stop-color:#1e40af;stop-opacity:0.1" />
    </radialGradient>
  </defs>
  
  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bgGradient2)"/>
  <rect width="1200" height="630" fill="url(#spotlight)"/>
  
  <!-- Network pattern -->
  <g opacity="0.15" stroke="#3b82f6" stroke-width="1" fill="none">
    <line x1="0" y1="100" x2="1200" y2="150"/>
    <line x1="0" y1="200" x2="1200" y2="180"/>
    <line x1="0" y1="300" x2="1200" y2="320"/>
    <line x1="0" y1="400" x2="1200" y2="380"/>
    <line x1="0" y1="500" x2="1200" y2="520"/>
    
    <line x1="200" y1="0" x2="180" y2="630"/>
    <line x1="400" y1="0" x2="420" y2="630"/>
    <line x1="600" y1="0" x2="580" y2="630"/>
    <line x1="800" y1="0" x2="820" y2="630"/>
    <line x1="1000" y1="0" x2="980" y2="630"/>
  </g>
  
  <!-- Security icons -->
  <g transform="translate(50, 50)" opacity="0.2">
    <!-- Lock icon -->
    <rect x="10" y="25" width="30" height="25" rx="3" fill="#60a5fa" stroke="#3b82f6" stroke-width="2"/>
    <path d="M15 25 C15 20 20 15 25 15 C30 15 35 20 35 25" fill="none" stroke="#3b82f6" stroke-width="2"/>
  </g>
  
  <g transform="translate(1050, 450)" opacity="0.2">
    <!-- Shield icon -->
    <path d="M25 5 C25 5 40 10 40 30 C40 50 25 60 25 60 C25 60 10 50 10 30 C10 10 25 5 25 5 Z" fill="#60a5fa" stroke="#3b82f6" stroke-width="2"/>
    <path d="M25 15 L35 25 L22.5 37.5 L15 30 Z" fill="#1e40af"/>
  </g>
  
  <!-- Main content -->
  <g transform="translate(100, 180)">
    <!-- Logo/Brand -->
    <text x="0" y="60" font-family="Arial, sans-serif" font-size="64" font-weight="bold" fill="#ffffff">
      SESECPRO
    </text>
    
    <!-- Tagline -->
    <text x="0" y="120" font-family="Arial, sans-serif" font-size="32" fill="#94a3b8">
      Ciberseguridad Avanzada
    </text>
    
    <!-- Key message -->
    <text x="0" y="170" font-family="Arial, sans-serif" font-size="24" fill="#cbd5e1">
      Protege tu mundo digital con nuestras soluciones especializadas
    </text>
    
    <!-- Call to action -->
    <rect x="0" y="200" width="300" height="50" rx="25" fill="#3b82f6"/>
    <text x="150" y="232" font-family="Arial, sans-serif" font-size="20" fill="white" text-anchor="middle">
      Evalúa tu Riesgo Ahora
    </text>
  </g>
  
  <!-- Bottom branding -->
  <text x="600" y="580" font-family="Arial, sans-serif" font-size="16" fill="#64748b" text-anchor="middle">
    sesecpro.es • Soluciones de Ciberseguridad
  </text>
</svg>